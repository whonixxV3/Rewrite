    local firstHolder
    for _, toggle in pairs(ToggleRefs) do
        if toggle and toggle.Holder then
            firstHolder = toggle.Holder
            break
        end
    end
    if not firstHolder then return end

    local screenGui = GetScreenGui(firstHolder)
    if not screenGui then return end

    local tip = Instance.new("TextLabel")
    tip.Name = "CustomTooltip"
    tip.BackgroundColor3 = Color3.fromRGB(48, 45, 65) 
    tip.BackgroundTransparency = 0.05
    tip.TextColor3 = Color3.fromRGB(255, 255, 255) 
    tip.TextSize = 14
    tip.Font = Enum.Font.Gotham 
    tip.TextWrapped = false
    tip.TextXAlignment = Enum.TextXAlignment.Center
    tip.TextYAlignment = Enum.TextYAlignment.Center
    tip.Visible = false
    tip.ZIndex = 999
    tip.BorderSizePixel = 0
    tip.Parent = screenGui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = tip

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(40, 40, 40) 
    stroke.Thickness = 1
    stroke.Parent = tip

    for name, text in pairs(tooltips) do
        local toggle = ToggleRefs[name]
        if toggle and toggle.Holder then
            toggle.Holder.MouseEnter:Connect(function()
                tip.Text = "  " .. text .. "  "

                local textSize = TextService:GetTextSize(
                    tip.Text,
                    14,
                    Enum.Font.Gotham,
                    Vector2.new(999, 999)
                )

                local width = textSize.X + 20
                local height = textSize.Y + 14

                tip.Size = UDim2.fromOffset(width, height)

                local holderPos = toggle.Holder.AbsolutePosition
                local holderSize = toggle.Holder.AbsoluteSize
                local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(1920, 1080)

                local x = holderPos.X + holderSize.X + 2
                local y = holderPos.Y + (holderSize.Y / 2) - (height / 2)

                if x + width > viewport.X - 5 then
                    x = holderPos.X - width - 2
                end

                if y < 5 then
                    y = 5
                end
                if y + height > viewport.Y - 5 then
                    y = viewport.Y - height - 5
                end

                tip.Position = UDim2.fromOffset(x, y)
                tip.Visible = true
            end)

            toggle.Holder.MouseLeave:Connect(function()
                tip.Visible = false
            end)
        end
    end
