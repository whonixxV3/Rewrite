MainModule.EspGuardsBoxes = {}

function MainModule.ToggleEspGuards(enabled)
    MainModule.EspGuardsEnabled = enabled
    
    local function clearAllESP()
        for part, box in pairs(MainModule.EspGuardsBoxes) do
            if box and box.Parent then
                pcall(function() box:Destroy() end)
            end
        end
        MainModule.EspGuardsBoxes = {}
    end
    
    if enabled then
        if MainModule.EspGuardsThread then
            task.cancel(MainModule.EspGuardsThread)
        end
        
        MainModule.EspGuardsThread = task.spawn(function()
            while MainModule.EspGuardsEnabled do
                local activeParts = {}
                local liveFolder = workspace:FindFirstChild("Live")
                
                if liveFolder then
                    for _, model in ipairs(liveFolder:GetChildren()) do
                        if model:IsA("Model") and model:FindFirstChild("Humanoid") then
                            local humanoid = model:FindFirstChildOfClass("Humanoid")
                            local despawn = model:GetAttribute("BodyDespawntime")
                            
                            if humanoid and humanoid.Health > 0 and not despawn then
                                for _, part in ipairs(model:GetChildren()) do
                                    if part:IsA("BasePart") then
                                        activeParts[part] = true
                                        if not MainModule.EspGuardsBoxes[part] then
                                            local box = Instance.new("BoxHandleAdornment")
                                            box.Adornee = part
                                            box.Size = part.Size + Vector3.new(0.5, 0.5, 0.5)
                                            box.Color3 = Color3.fromRGB(255, 0, 0)
                                            box.Transparency = 0.5
                                            box.AlwaysOnTop = true
                                            box.ZIndex = 10
                                            box.Parent = part
                                            MainModule.EspGuardsBoxes[part] = box
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
                
                for part, box in pairs(MainModule.EspGuardsBoxes) do
                    if not activeParts[part] or not part:IsDescendantOf(workspace) then
                        pcall(function() box:Destroy() end)
                        MainModule.EspGuardsBoxes[part] = nil
                    end
                end
                
                task.wait(0.3)
            end
            
            clearAllESP()
        end)
        MainModule.Notify("ESP Guards", "Enabled", 3)
    else
        if MainModule.EspGuardsThread then
            task.cancel(MainModule.EspGuardsThread)
            MainModule.EspGuardsThread = nil
        end
        clearAllESP()
        MainModule.Notify("ESP Guards", "Disabled", 3)
    end
    MainModule.PlayBell()
    return true
end

